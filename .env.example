# dohwa-backend 환경 변수 예시
# 실제 개발 시 이 파일을 `.env` 로 복사해 값을 채운다.
# `.env` 는 `.gitignore` 대상 — 절대 커밋 금지.

# --- 서버 ---
# REST 서버 포트 (docker-compose 포트 매핑과 일치시킬 것)
REST_PORT=8000

# --- CORS ---
# 콤마로 여러 오리진 분리. 프로덕션에서는 도메인 정확 매칭만 허용.
# 개발: http://localhost:3000 (Next.js 프론트)
CORS_ORIGINS=http://localhost:3000

# --- Database (MySQL) ---
# docker-compose.yml 의 mysql 서비스에 맞춤.
# 스키마: `dohwa` / 사용자: `dohwa` / 비밀번호: `dohwa_dev`
DATABASE_URL=mysql://dohwa:dohwa_dev@localhost:3306/dohwa

# --- MySQL container (docker-compose 변수) ---
MYSQL_ROOT_PASSWORD=dohwa_dev_root
MYSQL_DATABASE=dohwa
MYSQL_USER=dohwa
MYSQL_PASSWORD=dohwa_dev
